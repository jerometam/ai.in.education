---
// src/pages/ideas.astro — 教學點子
import Base from '../layouts/Base.astro';
---
<Base title="教學點子">
  <div class="container" style="padding:60px 24px">
    <h1 style="margin-bottom:8px">💡 教學點子</h1>
    <p style="margin-bottom:40px">AI 融入各科教學嘅實戰靈感。</p>
    <div class="card-grid">
      <article class="card">
        <div class="card-icon">📋</div>
        <div class="card-cat">教學點子</div>
        <h3>Google Classroom + AI 自動批改</h3>
        <p>用 AI Agent 幫你收功課、批改、發送回饋。</p>
        <div class="card-tags"><span class="card-tag">常識</span><span class="card-tag">科學</span></div>
      </article>
      <article class="card">
        <div class="card-icon">📝</div>
        <div class="card-cat">教學點子</div>
        <h3>AI 改英文作文 — 2分鐘30篇</h3>
        <p>用 AI 快速批改英文作文，俾 detailed feedback。</p>
        <div class="card-tags"><span class="card-tag">英文</span></div>
      </article>
    </div>
  </div>
</Base>
